# BMAD Agent Development Automator — `_bmad/automation/qa-runbook.yaml` stub.
#
# Story 7.5 (FR40) — `init` writes this canonical default at the
# practitioner's project root: `<project_root>/_bmad/automation/qa-runbook.yaml`.
# Every documented surface below is OPT-IN with a discoverable enablement
# path. Each surface follows the loud-fail doctrine — a feature that WOULD
# fire markers when configured does NOT fire on absence (no auto-scrubbing-
# by-shame; no marker on absence of `masked_selectors` per Story 4.12 AC-5;
# `not_configured` is the default Tier-3 evidence-tier posture per Story 4.8).
#
# The stub ships ALL surfaces commented-out by default; uncomment the worked
# example block for the surface you want to enable, then edit the values.
# Re-run `/bmad-automation init --overwrite-confirmed` (Story 7.6) to reset
# to defaults; otherwise this file is USER-OWNED and customizations are
# preserved across re-installs (FR42).

# ---
# masked_selectors — opt-in (default: absent → drivers persist evidence raw)
# Story 4.12; FR49 | NFR-S2
# How to enable: uncomment the block below and list the selectors that
# should be redacted from QA evidence (Playwright traces + HTTP transcripts).
# Empty by default per Story 4.12 AC-5 ("no marker on absence of
# `masked_selectors`"); the Automator does NOT auto-scrub.
# Worked example (uncomment to enable):
# masked_selectors:
#   - "input[type=password]"
#   - "[data-test-id=\"sensitive\"]"
# ---

# ---
# mobile_app_package_name — REQUIRED for `project_type: mobile`; IGNORED for web/api
# Story 9.3 — Phase 1.5 mobile QA via mobile MCP per ADR-007
# Source: FR-P1.5-2 | FR17 (see _bmad-output/planning-artifacts/prd.md lines 928, 851)
# Mobile-app package name OR iOS bundle identifier. Consumed by the mobile-MCP
# driver's `launch_app` at AC-iteration start (Story 9.3). REQUIRED for
# `project_type: mobile`; IGNORED for `project_type: web|api`. The value MUST be
# the runtime-installed app's identifier (Android: `com.example.app`; iOS:
# `com.example.MyApp`). The mobile-MCP server resolves this against the
# connected device's installed-apps list via `mobile_list_apps` if needed; the
# practitioner sets this once per project.
# Worked example (uncomment to enable for mobile projects):
# mobile_app_package_name: com.example.app
# ---

# ---
# tier_3_semantic_verification — opt-in (default: not_configured)
# Story 4.8; FR20 | FR21
# How to enable: uncomment the block below and configure a semantic
# verification provider (LLM judge, equivalent acceptance-threshold
# evaluator). When absent, QA emits a `Tier-3-not-configured` marker
# ONLY on ACs that declare Tier-3 as `required` in the QA Behavioral Plan;
# ACs declaring Tier-3 as `not_applicable` (default) verify with
# Tier-1 mechanical + Tier-2 outcome evidence alone.
# Worked example (uncomment to enable):
# tier_3_semantic_verification:
#   provider: <name-of-llm-judge-or-equivalent>
#   acceptance_threshold: 0.85
# ---

# ---
# behavioral_plan_overrides — opt-in (default: absent → QA generates plan from ACs)
# Story 4.1; FR23 | FR25
# How to enable: uncomment the block below to override per-AC expected
# evidence tiers and exploratory-heuristic applicability for specific
# stories. Story 4.1's QA Behavioral Plan generator reads these overrides
# at plan-generation time and persists the resolved plan into the story
# doc's `## QA Behavioral Plan` section. Use sparingly — overrides
# compromise the run-to-run plan-independence per FR25 verbatim.
# Worked example (uncomment to enable):
# behavioral_plan_overrides:
#   <story-id>:
#     ac_<n>:
#       expected_evidence_tier: tier-2-outcome
#       semantic_verification_requirement: not_applicable
#       # heuristic_opt_out — opt-in per-AC escape valve (Story 19.1; FR-P2-5 / ADR-010)
#       # List exploratory heuristics to SKIP for this AC. Each value MUST be one of
#       # the closed 7-set (see the `heuristics` block below). Use when a heuristic is
#       # structurally inapplicable to this AC's surface; the skip surfaces a
#       # `heuristic-skipped` marker (Story 19.2), never a silent drop.
#       heuristic_opt_out: [rate-limit-boundary]
# ---

# ---
# heuristics — opt-in (default: absent → ALL ADR-010 defaults active per project type)
# Story 19.1; FR-P2-5 | ADR-010
# How to enable: uncomment the block below and set per-project-type, per-heuristic
# activation. Shape: `heuristics.{web,api,mobile}.<heuristic-name>: enabled | disabled`.
# The closed 7-heuristic set (FROZEN_HEURISTIC_NAMES; ADR-010) is:
#   empty-state, error-state, auth-boundary           (the MVP trio, Story 4.9)
#   rate-limit-boundary, locale-i18n-edge,            (the 4 added in ADR-010)
#   large-input-boundary, permission-boundary
# Documented defaults (ADR-010 applicability matrix, ratified 2026-06-10):
#   web = all 7 enabled; api = all 7 enabled;
#   mobile = 6 of 7 (rate-limit-boundary EXCLUDED — rapid-request driving is
#     impractical through the mobile-MCP UI surface and would emit noisy
#     `heuristic-skipped` markers).
# ABSENCE of this block is NOT a marker (FR42 user-owned file — absence means
# "all ADR-010 defaults active"), mirroring `masked_selectors` above. Uncommenting
# a single project-type/heuristic line is enough to override just that default;
# unlisted heuristics keep their ADR-010 default.
# Worked example (uncomment to enable; values shown ARE the ADR-010 defaults):
# heuristics:
#   web:
#     empty-state: enabled
#     error-state: enabled
#     auth-boundary: enabled
#     rate-limit-boundary: enabled
#     locale-i18n-edge: enabled
#     large-input-boundary: enabled
#     permission-boundary: enabled
#   api:
#     empty-state: enabled
#     error-state: enabled
#     auth-boundary: enabled
#     rate-limit-boundary: enabled
#     locale-i18n-edge: enabled
#     large-input-boundary: enabled
#     permission-boundary: enabled
#   mobile:
#     empty-state: enabled
#     error-state: enabled
#     auth-boundary: enabled
#     rate-limit-boundary: disabled   # excluded on mobile per ADR-010
#     locale-i18n-edge: enabled
#     large-input-boundary: enabled
#     permission-boundary: enabled
# ---

