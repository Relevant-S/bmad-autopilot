# BMAD Agent Development Automator — `_bmad/automation/config.yaml` stub.
#
# Story 7.5 (FR40) — `init` writes this canonical default at the
# practitioner's project root: `<project_root>/_bmad/automation/config.yaml`.
# Every documented default below is traceable to its source FR/NFR via the
# `# Source:` cross-reference line. Every line citation references
# `_bmad-output/planning-artifacts/prd.md` in the planning workspace.
#
# To customize: edit the value below the relevant `# Source:` block.
# To re-derive defaults: re-run `/bmad-automation init --overwrite-confirmed`
# (Story 7.6 owns the non-destructive guard + override path).
#
# This file is USER-OWNED — Story 7.6's additive-merge layer preserves your
# customizations on re-init; new fields introduced by future Automator
# upgrades are added without overwriting existing values
# (see `_bmad-output/planning-artifacts/epics.md` lines 3050-3051).

# Whole-story retry budget. Orchestrator routes patch-bucket findings back to
# the responsible specialist up to this many times before assembling an
# escalation bundle (Story 5.1; FR8 verbatim).
# Source: FR8 (see _bmad-output/planning-artifacts/prd.md line 819)
# Default rationale: 2 retries balance recovery from transient findings against
# unbounded loop-amplified cost; reference-project runs settled here.
retry_budget: 2

# Per-epic retry-budget multiplier. When an epic is driven via
# `/bmad-automation run --epic <epic-id>`, the Orchestrator enforces a
# cumulative per-epic retry ceiling SEPARATE from (and additive on top of) the
# per-story `retry_budget` above. The effective ceiling is
# `per_epic_retry_budget_multiplier × story_count`; exhausting it pauses the
# epic at the next story-completion boundary with an `epic-budget-exhausted`
# loud-fail marker (Story 15.2). Must be an integer >= 1.
# Source: FR-P2-1 (see _bmad-output/planning-artifacts/prd.md post-MVP FRs)
# Default rationale: 2× story count bounds aggregate retry cost at epic scope
# with the same loud-fail discipline as the per-story budget, while leaving
# headroom for a minority of stories to use their full per-story retries.
per_epic_retry_budget_multiplier: 2

# Per-sprint retry budget (absolute override). When a sprint is driven via
# `/bmad-automation run --sprint <sprint-id>`, the Orchestrator enforces a
# cumulative per-sprint retry ceiling SEPARATE from (and additive on top of) the
# per-epic and per-story budgets. By default the ceiling is AUTO-COMPUTED from
# `per_sprint_retry_budget_multiplier × epic_count + retry_budget ×
# unassigned_story_count`; exhausting it pauses the sprint at the next unit-
# completion boundary (`sprint-paused-on-budget`) — the in-flight unit is allowed
# to finish (sensor-not-advisor). Set this field to an absolute integer to
# OVERRIDE the computed ceiling (0 = no per-sprint retries); omit it (the default)
# to auto-compute. Distinct from `per_epic_retry_budget_multiplier` above, which
# is a multiplier, not an absolute value.
# Source: FR-P2-2 (see _bmad-output/planning-artifacts/prd.md post-MVP FRs)
# Default rationale: the auto-computed formula gives a tight aggregate ceiling
# (~2× the epic count) that bounds runaway sprint-level retry cost while leaving
# each contained epic its own per-epic headroom; override only when a specific
# sprint needs a hand-set ceiling.
# Note: 0 is treated as no ceiling (unlimited); minimum enforcement value is 1
# (pauses when any unit's cumulative retries reach 1 total across the sprint).
# per_sprint_retry_budget: 12

# Sprint escalation-rate threshold (fraction in (0.0, 1.0]). When a sprint is
# driven via `/bmad-automation run --sprint <sprint-id>`, the Orchestrator emits
# an INFORMATIONAL `sprint-escalation-rate-exceeded` marker once the cumulative
# `escalated_stories / stories_completed` exceeds this fraction. The marker is
# non-blocking (sensor-not-advisor — the sprint continues; the practitioner
# decides whether to pause manually); it surfaces systemic escalation as a
# quality-axis signal distinct from the cost-axis `sprint-paused-on-budget`.
# Source: FR-P2-2 (see _bmad-output/planning-artifacts/prd.md post-MVP FRs)
# Default rationale: 0.25 is calibrated from the PRD's 15–25% retry-budget-
# exhaustion target band (Technical Success criteria) — above a quarter of
# stories escalating signals a systemic quality issue worth surfacing.
sprint_escalation_rate_threshold: 0.25

# Per-specialist invocation timeout (minutes). Specialist invocations exceeding
# this signal a hang and surface a `specialist-timeout: {specialist}` loud-fail
# marker with a diagnostic pointer rather than open-endedly waiting (Story 6.7).
# Source: NFR-P2 (see _bmad-output/planning-artifacts/prd.md line 935)
# Default rationale: 15 minutes accommodates legitimate long-running specialist
# work (review against large diffs, QA env-provisioning) while catching hangs
# inside one active-session window — revisited per release against reference-
# project specialist runtime distributions.
specialist_timeout_minutes: 15

# Per-story cost ceiling (USD). Orchestrator surfaces a `cost-near-ceiling`
# marker at 75% of this value (Story 6.5) and refuses further specialist
# dispatches once the ceiling is exceeded; ceiling enforcement protects
# against runaway-cost adoption-killer scenarios (NFR-P1 verbatim — "$5 per
# story before the 'default implementation loop' positioning is earned").
# Source: NFR-P1 (see _bmad-output/planning-artifacts/prd.md line 934)
# Default rationale: $5 is the published per-story ceiling — the boundary
# between "default implementation loop" and "escalation territory". Unit is
# USD; the numeric value is what `cost_telemetry.py` compares against.
cost_ceiling_per_story: 5

# QA evidence bundle size budget (MB). Per-run evidence at
# `_bmad-output/qa-evidence/{story-id}/{run-id}/` is truncated above this
# limit with an `evidence-truncated: {story-id}` loud-fail marker rather
# than unbounded disk growth (Story 4.12).
# Source: NFR-P6 (see _bmad-output/planning-artifacts/prd.md line 939)
# Default rationale: 50 MB accommodates a typical screenshot-bearing QA
# evidence bundle (Playwright traces + per-AC screenshots + HTTP transcripts)
# without growing unbounded across long retry chains. NFR-P6 names the
# default as "TBD, published pre-release"; this canonical value settles it.
evidence_max_size_mb: 50

# BMAD story-doc template-version tolerance window (number of minor versions
# behind the current Automator-supported version). Story-doc reads succeed
# silently within the window; out-of-window versions emit a
# `story-doc-version-out-of-window` marker with upgrade guidance
# (Story 7.7 owns the detector + the marker).
# Source: FR43 | NFR-I5 (see _bmad-output/planning-artifacts/prd.md line 868)
# Default rationale: N-2 (two minor versions back) — accommodates one full
# upgrade cycle so an in-progress story straddling a BMAD release does not
# break mid-loop while still flagging genuine drift before it accumulates.
story_doc_version_tolerance_window: 2

# Pointer to the canonical dependency version pins manifest. The pins
# themselves LIVE in `_bmad/automation/dependencies.yaml` (Story 7.3's
# cell-1 portable manifest per ADR-002 + SDN-001); this field is a
# DOCUMENTED POINTER, not an inline duplicate, to prevent drift between
# two sources of truth for the same fact.
# Source: FR40 (see _bmad-output/planning-artifacts/prd.md line 865)
# Default rationale: the phrase "dependency version pins (referencing
# `dependencies.yaml`)" at epics.md line 3017 names this interpretation
# explicitly; do not inline duplicate values here.
dependency_version_pins:
  source: _bmad/automation/dependencies.yaml

# Install method recorded by `init` per Story 7.2. UNCOMMENT only if you
# need to override the resolved install method by hand — the production
# path is `loud_fail_harness.install_path.record_install_method` writing
# this key on first install (plugin-primitive | git-clone-symlink). A
# hard-coded value here would silently override the resolved method.
# Source: FR35 | FR36 (see _bmad-output/planning-artifacts/prd.md lines 860-861)
# Default rationale: omitted by default; Story 7.2's runtime path
# additively adds the resolved value on first call.
# install_method: <set by `init` per Story 7.2; do not edit by hand>

# First-run TEA-boundary orientation tracking. `init` reads this field
# before emitting the FR34 one-time TEA-vs-Automator orientation message
# in terminal output (Story 7.8). On first emission, `init` flips this
# field to `true`; subsequent re-runs read `true` and skip the message
# per FR34's "one-time" qualifier. To force re-emission, run
# `/bmad-automation init --overwrite-confirmed --yes` (Story 7.6's
# explicit-override path; resets the entire config to canonical defaults).
# Source: FR34 (see _bmad-output/planning-artifacts/prd.md line 856)
# Default rationale: `false` on fresh install — the orientation message
# has not yet been shown; `init`'s first successful run on the project
# is the "first run" the FR34 one-time qualifier names.
tea_boundary_orientation_emitted: false

# Project type discriminator. Drives Orchestrator dispatch to project-type-
# specific QA driver (Playwright MCP for web, HTTP for api, mobile MCP for
# mobile) AND `dependencies.yaml`'s `by_project_type` resolution at init
# preconditions. `init` writes the detected value here automatically per the
# detection rule documented in `project_type_detection.py`'s module
# docstring; practitioners may edit this to override the auto-detection.
# Source: FR40 | FR-P1.5-2 (see _bmad-output/planning-artifacts/prd.md lines 865, 928)
# Default rationale: written by `init` at install time per Story 9.2's
# detection rule (mobile via ios/+android/ | Flutter pubspec.yaml | Expo
# app.json → web via package.json web frameworks → api via Node/Python/
# Go/Rust/JVM markers). The line below ships as a commented placeholder
# (parallel to the `install_method` convention at template lines 81-89);
# runtime-write at `init` time replaces it with the detected value.
# Valid values: "web" | "api" | "mobile".
# project_type: <set by `init` per Story 9.2; do not edit by hand unless overriding auto-detection>

# Phase-1.5 LAD (4th adversarial review layer) opt-in gate. When
# `enabled: true`, the orchestrator dispatches the Review-LAD wrapper
# alongside Review-BMAD as a 4-layer parallel-pass review per Story 10.4
# `dispatch_four_layer_review`; the LAD layer composes
# `lad_mcp_server`'s `code_review` MCP tool via the OpenRouter dual-
# reviewer parallelism architecture (ADR-008). When `enabled: false`
# (the default) the 4-layer dispatch is bit-identical to the Phase-1
# 3-layer dispatch — zero LAD Task-tool invocation, zero LAD dispatch
# log, zero `Review-LAD` cost row, zero `lad` entry in `failed_layers`.
# Source: FR-P1.5-1 | FR29 (see _bmad-output/planning-artifacts/prd.md
# Phase 1.5 supplement)
# Default rationale: `false` per the opt-in posture (Phase 1.5 default-
# off; LAD is an opt-in extension layer rather than a mandatory leg of
# the review surface).
review_lad:
  enabled: false
  # Environment variable name whose value is forwarded to the
  # `lad_mcp_server` MCP server at startup as `OPENROUTER_API_KEY`
  # (Story 10.5 owns the runtime env-var-handling discipline + the
  # `LAD-skipped` marker emission for the missing-env-var precondition
  # path). Default canonical name per ADR-008 line 692; operators may
  # override here if the OpenRouter API key is exported under a
  # different variable name in their shell.
  api_key_env_var: "OPENROUTER_API_KEY"
